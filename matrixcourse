//Матрица
#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

//Ввод от руки
void fillarr(int** a, int n) {
    cout << "Введите элементы матрицы (" << n << "x" << n << "): " << endl;
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++) {
            cout << "a[" << i << "][" << j << "] = ";
            if (!(cin >> a[i][j])) {
                cout << "Ошибка: некорректный ввод!" << endl;
                exit(1);
            }
        }
}

//Случайно
void randarr(int** a, int n, int lo, int hi) {
    srand((unsigned)time(0));
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            a[i][j] = lo + rand() % (hi - lo + 1);
}

//Вывод матрицы
void printmatrix(int** a, int n) {
    cout << "Матрица:";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++)
            cout << a[i][j] << "\t";
        cout << "\n";
    }
}



//Наибольший положительный напобочной диагонали
bool maxplusofpdiag(int** a, int n, int& result) {
    bool found = false;
    for (int i = 0; i < n; i++) {
        int j = n - 1 - i;
        if (a[i][j] > 0) {
            if (!found || a[i][j] > result) {
                result = a[i][j];
                found = true;
            }
        }
    }
    return found;
}

//Кратно 3
void countmultof3(int** a, int n, int* cnt) {
    for (int i = 0; i < n; i++) {
        cnt[i] = 0;
        for (int j = 0; j < n; j++)
            if (a[i][j] % 3 == 0)
                cnt[i]++;
    }
}

