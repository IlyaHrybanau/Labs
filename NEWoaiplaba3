#include <iostream>
#include <conio.h>
using namespace std;

double member(double a1, double d, int n) {
    if (n == 1) return a1;
    return member(a1, d, n - 1) + d;
}

double sumrecur(double a1, double d, int n) {
    if (n == 1) return a1;
    return sumrecur(a1, d, n - 1) + member(a1, d, n);
}

int main() {
    setlocale(LC_ALL, "Russian");

    double a1, d;
    int n;

    cout << "Введите первый член прогрессии: ";
    cin >> a1;
    cout << "Введите разность прогрессии: ";
    cin >> d;
    cout << "Введите количество членов n: ";
    cin >> n;

    cout << "\nЧлены прогрессии: ";
    for (int i = 1; i <= n; i++)
        cout << member(a1, d, i) << " ";

    cout << "\nСумма первых " << n << " членов = " << sumrecur(a1, d, n) << endl;

    _getch();
    return 0;
}