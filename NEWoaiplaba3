#include <iostream>
#include <conio.h>
#include <ctime>
using namespace std;

void fillarr(int* arr, int n) {
    for (int i = 0; i < n; i++)
        arr[i] = rand() % 100 - 50;
}

void fillarr(double* arr, int n) {
    for (int i = 0; i < n; i++)
        arr[i] = (rand() % 2000 - 1000) / 10.0;
}

void fillarr(char* arr, int n) {
    for (int i = 0; i < n; i++)
        arr[i] = 'a' + rand() % 26;
}

void printarr(int* arr, int n) {
    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << endl;
}

void printarr(double* arr, int n) {
    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << endl;
}

void printarr(char* arr, int n) {
    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << endl;
}

int minval(int* arr, int n) {
    int m = arr[0];
    for (int i = 1; i < n; i++)
        if (arr[i] < m) m = arr[i];
    return m;
}

double minval(double* arr, int n) {
    double m = arr[0];
    for (int i = 1; i < n; i++)
        if (arr[i] < m) m = arr[i];
    return m;
}

char minval(char* arr, int n) {
    char m = arr[0];
    for (int i = 1; i < n; i++)
        if (arr[i] < m) m = arr[i];
    return m;
}

int summinlast(int* arr, int n) {
    return minval(arr, n) + arr[n - 1];
}

double summinlast(double* arr, int n) {
    return minval(arr, n) + arr[n - 1];
}

int summinlast(char* arr, int n) {
    return (int)minval(arr, n) + (int)arr[n - 1];
}

int main() {
    setlocale(LC_ALL, "Russian");
    srand(time(0));

    int in, dn, cn;

    cout << "Сколько элементов в массиве int? ";
    cin >> in;
    int* iarr = new int[in];
    fillarr(iarr, in);
    cout << "Массив int: ";
    printarr(iarr, in);
    cout << "Мин + последний = " << summinlast(iarr, in) << endl;

    cout << "\nСколько элементов в массиве double? ";
    cin >> dn;
    double* darr = new double[dn];
    fillarr(darr, dn);
    cout << "Массив double: ";
    printarr(darr, dn);
    cout << "Мин + последний = " << summinlast(darr, dn) << endl;

    cout << "\nСколько элементов в массиве char? ";
    cin >> cn;
    char* carr = new char[cn];
    fillarr(carr, cn);
    cout << "Массив char: ";
    printarr(carr, cn);
    cout << "Мин ('" << minval(carr, cn) << "') + последний ('"
         << carr[cn - 1] << "') по ASCII = " << summinlast(carr, cn) << endl;

    delete[] iarr;
    delete[] darr;
    delete[] carr;

    _getch();
    return 0;
}

