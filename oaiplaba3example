//Ex.1
#include <iostream>
using namespace std;

// Функция для массива целых чисел
int sumMinLast(int arr[], int size) {
    if (size <= 0) return 0;
    
    int minVal = arr[0]; // Предполагаем, что первый элемент минимальный
    for (int i = 1; i < size; i++) {
        if (arr[i] < minVal) {
            minVal = arr[i]; // Обновляем минимум, если нашли число меньше
        }
    }
    return minVal + arr[size - 1];
}

// Функция для массива вещественных чисел
double sumMinLast(double arr[], int size) {
    if (size <= 0) return 0.0;
    
    double minVal = arr[0];
    for (int i = 1; i < size; i++) {
        if (arr[i] < minVal) {
            minVal = arr[i];
        }
    }
    return minVal + arr[size - 1];
}

// Функция для массива символов (работает с кодами ASCII)
int sumMinLast(char arr[], int size) {
    if (size <= 0) return 0;
    
    char minVal = arr[0];
    for (int i = 1; i < size; i++) {
        if (arr[i] < minVal) {
            minVal = arr[i];
        }
    }
    // Возвращаем сумму кодов символов
    return (int)minVal + (int)arr[size - 1];
}

int main() {
    // Данные для проверки
    int numsInt[] = {10, 2, 5, 7};           // min=2, last=7. Сумма: 9
    double numsDouble[] = {3.5, 1.2, 4.8};   // min=1.2, last=4.8. Сумма: 6.0
    char chars[] = {'f', 'b', 'z'};          // min='b'(98), last='z'(122). Сумма: 220

    cout << "Сумма (int): " << sumMinLast(numsInt, 4) << endl;
    cout << "Сумма (double): " << sumMinLast(numsDouble, 3) << endl;
    cout << "Сумма кодов (char): " << sumMinLast(chars, 3) << endl;

    return 0;
}

