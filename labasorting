#include <iostream>
#include <ctime>
#include <cstdlib>
using namespace std;

void bubbleSort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int interpolSearch(int arr[], int size, int key) {
    int low = 0;
    int high = size-1;
    int mid;

    while (arr[low] < key && arr[high] >= key) {
        mid = low + (key - arr[low]) * (high - low) / (arr[high] - arr[low]);

        if (arr[mid] < key) {
            low = mid + 1;
        }
        else {
            if (arr[mid] < key) {
                high = mid - 1;
            }
            else {
                return mid;
            }
        }
    }

    if (arr[low] == key) {
        return low;
    }
    else {
        if (arr[high] == key) {
            return high;
        }
        else {
            return -1;
        }
    }
}

