#include <iostream>
using namespace std;

void delen(int a, int b, int* res) {
    if (b!=0) {
        *res = a%b;
    }
    else {
        cout << "Ошибка" << endl;
    }

}

int main() {
    int result;

    cout << "Остаток от деления"<< endl;

    delen(10, 3, &result);
    cout <<"При 10 и 3 = "<< result << endl;

    delen(52, 50, &result);
    cout <<"При 52 и 50 = "<< result << endl;

    delen(40, 19, &result);
    cout <<"При 40 и 19 = "<< result << endl;


    return 0;
}

