void getSphere(double r, double &s, double &v) {
    const double PI = 3.1415926535; 
    
    s = 4 * PI * r * r;           
    v = (4.0 / 3.0) * PI * r * r * r;
}

int main() {
    double radius1 = 5.0, area1, volume1;
    double radius2 = 12.5, area2, volume2;


