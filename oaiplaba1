//Ex.2
#include <iostream>
using namespace std;

void delen(int a, int b, int* res) {
    if (b != 0) {
        *res = a % b;
    } else {
        cout << "Ошибка: деление на ноль!" << endl;
    }
}

int main() {
    int result; 

    delen(17, 5, &result);
    cout << "17 % 5 = " << result << endl;

    delen(42, 10, &result);
    cout << "42 % 10 = " << result << endl;

    delen(9, 4, &result);
    cout << "9 % 4 = " << result << endl;

    return 0;
}

