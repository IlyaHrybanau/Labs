
#include <iostream>
#include <ctime>
#include <cstdlib>
#include <iomanip>
#include <conio.h>
using namespace std;


int main() {
        setlocale(LC_ALL, ".1251");
        srand(time(0));

        //массив символов
        const int MAX = 10;
        char mystring[MAX];
        cout << "Изначально" << endl;
        for (int j = 0; j < 5; j++) {
                cout << mystring[j] << " ";
        }
        cout << "\n";

        cout << "введите символы: ";
        for (int i = 0; i < MAX - 1; i++)
                cin >> mystring[i];

        mystring[MAX - 1] = '\0';
        cout << "Вывод строки: " << mystring << endl;
        _getch();

        cout << "Вывод посимвольно: " << endl;
        for (int i = 0; mystring[i] != '\0'; i++) {
                cout << mystring[i] << " ";
        }
        cout << "\n";
        // вывод: вместо мусора изначально вывелось что мы ввели



        //Первый указатель
        char* ptr;
        ptr = mystring;

        cout << "soderjimoe stroki" << ptr << endl;
        cout << "adress = " << (void*)ptr << endl;
        cout << "6punkt = " << (void*)ptr << endl;


        /*статический одномерный*/
        short arrnum[5];
        for (int i = 0; i < 5; i++) {
                arrnum[i] = i + 1;
        }

        cout << "До ввода " << endl;
        for (int i = 0; i < 5; i++) {
                cout << arrnum[i] << " ";
        }
        cout << "\n";

        cout << "Введите массив" << endl;
        for (int i = 0; i < 5; i++) {
                cin >> arrnum[i];
        }
        cout << "\n";

        cout << "После ввода " << endl;
        for (int i = 0; i < 5; i++) {
                cout << arrnum[i] << " ";
        }
        cout << "\n";
        _getch();


        // указатель 2 на массив коротких целых
        short* arrsymb;

        // динамический одномерный массив через ptr
        cout << "Динамический массив через ptr до ввода" << endl;
        ptr = new char[5];
        for (int i = 0; i < 5; i++) {
                cout << (int)ptr[i] << " ";
        }
        cout << "\n";
        // вывод: мусор, т.к. не инициализирован

        cout << "Введите 5 символов: ";
        for (int i = 0; i < 5; i++) {
                cin >> ptr[i];
        }

        cout << "После ввода: " << endl;
        for (int i = 0; i < 5; i++) {
                cout << ptr[i] << " ";
        }
        cout << "\n";
        _getch();

        delete[] ptr;
        cout << "Динамический массив удален" << endl;


        // двумерный динамический массив через arrsymb
        int rows = 3, cols = 4;
        arrsymb = new short[rows * cols];

        cout << "Введите двумерный массив 3x4: " << endl;
        for (int i = 0; i < rows; i++) {
                for (int j = 0; j < cols; j++) {
                        cout << "[" << i << "][" << j << "] = ";
                        cin >> arrsymb[i * cols + j];
                }
        }

        cout << "После ввода: " << endl;
        for (int i = 0; i < rows; i++) {
                for (int j = 0; j < cols; j++) {
                        cout << arrsymb[i * cols + j] << " ";
                }
                cout << "\n";
        }
        _getch();

        delete[] arrsymb;
        cout << "Двумерный динамический массив удален" << endl;


        // трехмерный массив
        int arr3d[2][3][4];
        arr3d[1][2][3] = 99;

        cout << "Элемент arr3d[1][2][3] через индексацию: " << arr3d[1][2][3] << endl;
        // вывод через имя массива как указатель
        cout << "Элемент через указатель: " << *(*(*(arr3d + 1) + 2) + 3) << endl;
        _getch();


        // указатель на двумерный массив
        int (*ptr2d)[3][4] = arr3d;

        cout << "Элемент через ptr2d: " << *(*(*(ptr2d + 1) + 2) + 3) << endl;
        // вывод: то же самое значение - ptr2d корректно указывает на arr3d
        _getch();


        return 0;
}


