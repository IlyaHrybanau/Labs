#include <iostream>
#include <string>

using namespace std;

// Функция принимает строку (по ссылке для скорости) и искомый символ
int countChar(const string& text, char target) {
    int count = 0;
    for (int i = 0; i < text.length(); i++) {
        if (text[i] == target) {
            count++;
        }
    }
    return count;
}

int main() {
    // Пример строки (можно заменить на ввод через getline(cin, S1))
    string S1 = "((Пример текста) с (несколькими) скобками)";

    // Считаем открывающиеся и закрывающиеся скобки
    int openCount = countChar(S1, '(');
    int closeCount = countChar(S1, ')');

    cout << "Строка: " << S1 << endl;
    cout << "Открывающих скобок: " << openCount << endl;
    cout << "Закрывающих скобок: " << closeCount << endl;

    // Сравниваем результаты
    if (openCount == closeCount) {
        cout << "Результат: Количество скобок совпадает." << endl;
    } else {
        cout << "Результат: Количество скобок НЕ совпадает." << endl;
    }

    return 0;
}

