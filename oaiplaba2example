#include <iostream>
#include <vector>

using namespace std;

const int N = 3; // Размерность квадратных матриц (можно изменить)

typedef double Matrix[N][N];

// Функция для вычисления квадрата матрицы (R = M * M)
void squareMatrix(Matrix M, Matrix R) {
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            R[i][j] = 0;
            for (int k = 0; k < N; k++) {
                R[i][j] += M[i][k] * M[k][j];
            }
        }
    }
}

// Функция для вычисления суммы элементов последней строки
double sumLastRow(Matrix M) {
    double sum = 0;
    for (int j = 0; j < N; j++) {
        sum += M[N - 1][j]; // Индекс последней строки: N-1
    }
    return sum;
}

// Вспомогательная функция для вывода матрицы
void printMatrix(Matrix M) {
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            cout << M[i][j] << "\t";
        }
        cout << endl;
    }
}

int main() {
    // Инициализация трех матриц
    Matrix A = {{1, 2, 3}, {4, 5, 6}, {1, 1, 1}};
    Matrix B = {{2, 0, 0}, {0, 2, 0}, {5, 5, 5}};
    Matrix C = {{1, 0, 1}, {0, 1, 0}, {0, 0, 1}};

    // Матрицы для хранения результатов квадратов (если нужно по задаче)
    // Но условие просит найти матрицу с наим. суммой строки среди исходных или их квадратов?
    // Обычно в таких задачах имеется в виду работа с исходными матрицами.
    
    double sumA = sumLastRow(A);
    double sumB = sumLastRow(B);
    double sumC = sumLastRow(C);

    cout << "Сумма последней строки A: " << sumA << endl;
    cout << "Сумма последней строки B: " << sumB << endl;
    cout << "Сумма последней строки C: " << sumC << endl;

    cout << "\nРезультат: ";
    if (sumA <= sumB && sumA <= sumC) {
        cout << "Матрица A имеет наименьшую сумму последней строки." << endl;
    } else if (sumB <= sumA && sumB <= sumC) {
        cout << "Матрица B имеет наименьшую сумму последней строки." << endl;
    } else {
        cout << "Матрица C имеет наименьшую сумму последней строки." << endl;
    }

    return 0;
}
