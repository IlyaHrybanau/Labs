using namespace std;

// Структура для анкетных данных
struct Student {
    string fio;
    int birthYear;
    string address;
    string parentsInfo;
    double averageGrade;
};

// Функция ввода массива студентов
void inputStudents(Student group[], int n) {
    for (int i = 0; i < n; i++) {
        cout << "--- Студент #" << i + 1 << " ---" << endl;
        cout << "ФИО: ";
        getline(cin >> ws, group[i].fio); // ws игнорирует лишние пробелы/переносы
        cout << "Год рождения: ";
        cin >> group[i].birthYear;
        cout << "Адрес: ";
        getline(cin >> ws, group[i].address);
        cout << "Сведения о родителях: ";
        getline(cin >> ws, group[i].parentsInfo);
        cout << "Средний балл: ";
        cin >> group[i].averageGrade;
    }
}

// Функция поиска лучшего студента (возвращает объект структуры)
Student findBestStudent(Student group[], int n) {
    int bestIndex = 0;
    for (int i = 1; i < n; i++) {
        if (group[i].averageGrade > group[bestIndex].averageGrade) {
            bestIndex = i;
        }
    }
    return group[bestIndex];
}

// Функция вывода данных о студенте
void printStudent(Student s) {
    cout << "ФИО: " << s.fio << " | Балл: " << s.averageGrade << endl;
}

int main() {
    int n;
    cout << "Введите количество студентов в группах: ";
    cin >> n;

    // Создаем два массива (группы)
    Student group1[100], group2[100]; // Или используйте динамический массив/vector

    cout << "\nЗАПОЛНЕНИЕ ГРУППЫ №1" << endl;
    inputStudents(group1, n);

    cout << "\nЗАПОЛНЕНИЕ ГРУППЫ №2" << endl;
    inputStudents(group2, n);

    // Ищем лучших в каждой группе
    Student best1 = findBestStudent(group1, n);
    Student best2 = findBestStudent(group2, n);

    cout << "\n--- РЕЗУЛЬТАТЫ ---" << endl;
    cout << "Лучший в группе 1: ";
    printStudent(best1);

    cout << "Лучший в группе 2: ";
    printStudent(best2);

    return 0;
}

