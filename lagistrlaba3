
#include <iostream>
using namespace std;

int main() {
    // ===== Определение переменных и массивов (Вариант 6) =====

    // 1. Одномерный символьный массив
    char arr1[5];

    // 2. Указатель на тип char
    char* ptr2;

    // 3. Статический одномерный массив коротких целых чисел
    static short arr3[4];

    // 4. Указатель на массив коротких целых чисел
    short* ptr4;

    // 5. Трёхмерный массив целых чисел
    int arr5[2][3][4];

    // 6. Указатель на двумерный массив целых чисел
    int (*ptr6)[3][4];


    // ===== Пункт 1: Проверить содержимое массива №1 до ввода =====
    cout << "\n--- Пункт 1: Содержимое arr1 до ввода ---" << endl;
    for (int i = 0; i < 5; i++) {
        cout << "arr1[" << i << "] = " << (int)arr1[i] << endl;
    }
    // Вывод: случайные (мусорные) значения, т.к. массив не инициализирован


    // ===== Пункт 2: Ввод данных в массив №1 =====
    cout << "\n--- Пункт 2: Ввод данных в arr1 (введите 5 символов через пробел) ---" << endl;
    for (int i = 0; i < 5; i++) {
        cout << "arr1[" << i << "] = ";
        cin >> arr1[i];
    }


    // ===== Пункт 3: Проверить содержимое arr1 после ввода =====
    cout << "\n--- Пункт 3: Содержимое arr1 после ввода ---" << endl;
    for (int i = 0; i < 5; i++) {
        cout << "arr1[" << i << "] = " << arr1[i] << endl;
    }


    // ===== Пункт 4: Присвоить ptr2 адрес arr1, вывести адреса и содержимое =====
    cout << "\n--- Пункт 4: Указатель ptr2 = arr1 ---" << endl;
    ptr2 = arr1;
    cout << "Адрес массива arr1:    " << (void*)arr1  << endl;
    cout << "Адрес указателя ptr2:  " << (void*)&ptr2 << endl;
    cout << "Значение ptr2 (адрес, на который указывает): " << (void*)ptr2 << endl;
    cout << "Содержимое ptr2 (разыменование): " << *ptr2 << endl;


    // ===== Пункт 5: Вывод массива через указатель ptr2 =====
    cout << "\n--- Пункт 5: Содержимое arr1 через ptr2 ---" << endl;
    for (int i = 0; i < 5; i++) {
        cout << "ptr2[" << i << "] = " << ptr2[i] << endl;
    }


    // ===== Пункт 6: Статический массив arr3 =====
    cout << "\n--- Пункт 6а: Содержимое arr3 до ввода ---" << endl;
    for (int i = 0; i < 4; i++) {
        cout << "arr3[" << i << "] = " << arr3[i] << endl;
    }
    // Статические массивы инициализируются нулями автоматически

    cout << "\n--- Пункт 6б: Ввод данных в arr3 (введите 4 числа типа short) ---" << endl;
    for (int i = 0; i < 4; i++) {
        cout << "arr3[" << i << "] = ";
        cin >> arr3[i];
    }

    cout << "\n--- Пункт 6в: Содержимое arr3 после ввода ---" << endl;
    for (int i = 0; i < 4; i++) {
        cout << "arr3[" << i << "] = " << arr3[i] << endl;
    }


    // ===== Пункт 7: Динамический массив через ptr2 =====
    cout << "\n--- Пункт 7а: Содержимое динамического char-массива до ввода ---" << endl;
    ptr2 = new char[5];
    for (int i = 0; i < 5; i++) {
        cout << "ptr2[" << i << "] = " << (int)ptr2[i] << endl;
    }
    // Динамический массив не инициализирован — мусорные значения

    cout << "\n--- Пункт 7б: Ввод данных в динамический массив (5 символов) ---" << endl;
    for (int i = 0; i < 5; i++) {
        cout << "ptr2[" << i << "] = ";
        cin >> ptr2[i];
    }

    cout << "\n--- Пункт 7в: Содержимое динамического массива после ввода ---" << endl;
    for (int i = 0; i < 5; i++) {
        cout << "ptr2[" << i << "] = " << ptr2[i] << endl;
    }


    // ===== Пункт 8: Двумерный динамический массив через ptr4 =====
    delete[] ptr2;
    cout << "\n--- Пункт 8: Двумерный динамический массив (3x4) через ptr4 ---" << endl;

    const int ROWS = 3, COLS = 4;
    ptr4 = new short[ROWS * COLS];

    cout << "Введите " << ROWS * COLS << " чисел типа short:" << endl;
    for (int i = 0; i < ROWS; i++) {
        for (int j = 0; j < COLS; j++) {
            cout << "ptr4[" << i << "][" << j << "] = ";
            cin >> ptr4[i * COLS + j];
        }
    }

    cout << "\nСодержимое двумерного динамического массива:" << endl;
    for (int i = 0; i < ROWS; i++) {
        for (int j = 0; j < COLS; j++) {
            cout << "ptr4[" << i << "][" << j << "] = " << ptr4[i * COLS + j] << "  ";
        }
        cout << endl;
    }

    delete[] ptr4;
    cout << "Двумерный динамический массив удалён." << endl;


    // ===== Пункт 9: Трёхмерный массив — вывод элемента через индексацию =====
    cout << "\n--- Пункт 9: Элемент arr5[1][2][3] через индексацию ---" << endl;
    arr5[1][2][3] = 42;
    cout << "arr5[1][2][3] = " << arr5[1][2][3] << endl;


    // ===== Пункт 10: Трёхмерный массив — вывод элемента через указатель =====
    cout << "\n--- Пункт 10: Элемент arr5[1][2][3] через указатель ---" << endl;
    cout << "*(*(*(arr5 + 1) + 2) + 3) = " << *(*(*(arr5 + 1) + 2) + 3) << endl;


    // ===== Пункт 11: Указатель ptr6 на двумерный массив, присвоить адрес arr5 =====
    cout << "\n--- Пункт 11: ptr6 = arr5, вывод через ptr6 ---" << endl;
    ptr6 = arr5;
    cout << "*(*(*(ptr6 + 1) + 2) + 3) = " << *(*(*(ptr6 + 1) + 2) + 3) << endl;


    cout << "\n===== Программа завершена =====" << endl;
    return 0;
}
